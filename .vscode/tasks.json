{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch",
      "dependsOn": ["watch:webview", "watch:extension"],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "watch:extension",
      "type": "npm",
      "script": "watch",
      "path": "packages/extension",
      "isBackground": true,
      "presentation": { "group": "watch", "reveal": "never" },
      "problemMatcher": {
        "owner": "esbuild",
        "source": "esbuild",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^✘ \\[ERROR\\] (.+)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[watch\\] build started$",
          "endsPattern": "^\\[watch\\] build finished$"
        }
      }
    },
    {
      "label": "watch:webview",
      "type": "npm",
      "script": "watch",
      "path": "packages/webview",
      "isBackground": true,
      "presentation": { "group": "watch", "reveal": "never" },
      "problemMatcher": {
        "owner": "esbuild-webview",
        "source": "esbuild",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^✘ \\[ERROR\\] (.+)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[watch\\] build started$",
          "endsPattern": "^\\[watch\\] build finished$"
        }
      }
    }
  ]
}
